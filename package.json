{
  "name": "genshin-loadout-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Genshin Impact loadout & team builder — pnpm monorepo",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,magenta \"pnpm --filter @app/backend start\" \"pnpm --filter @app/frontend dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint .",
    "format": "prettier --check .",
    "export:dataset": "tsx scripts/export-dataset.mts",
    "build:pages": "pnpm export:dataset && PAGES=true pnpm --filter @app/frontend build"
  },
  "devDependencies": {
    "@app/dataset": "workspace:*",
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.19.0"
}
