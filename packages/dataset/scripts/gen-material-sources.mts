/**
 * Generates frontend/src/data/materialSources.ts: a concise "where to get it" hint for every
 * material referenced by a character (ascension/talent) or weapon in our dataset. genshin-db
 * carries the source info (domain + weekdays, local-specialty region, boss drop, …) but our
 * dataset only stores {name, count}, so we snapshot a hint per material name for the UI (#6).
 *
 * Run: npx tsx packages/dataset/scripts/gen-material-sources.mts
 */
import { readFileSync, writeFileSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import gdb from "genshin-db";

const here = dirname(fileURLToPath(import.meta.url));
const ROOT = join(here, "..", "..", "..");
const DATA = join(ROOT, "data", "genshindb");
const OUT = join(ROOT, "frontend", "src", "data", "materialSources.ts");

const DAY_ABBR: Record<string, string> = {
  Monday: "Mon",
  Tuesday: "Tue",
  Wednesday: "Wed",
  Thursday: "Thu",
  Friday: "Fri",
  Saturday: "Sat",
  Sunday: "Sun",
};

function daysLabel(days?: string[]): string {
  if (!days || !days.length) return "";
  if (days.length >= 7) return "daily";
  return days.map((d) => DAY_ABBR[d] ?? d).join("/");
}

/** Build the most useful single-line hint for a material name. */
function hintFor(name: string): string {
  const m = gdb.materials(name, { queryLanguages: ["English"] }) as
    | { typeText?: string; dropDomainName?: string; daysOfWeek?: string[]; sources?: string[] }
    | undefined;
  if (!name || name.toLowerCase() === "mora") return "Ley lines, chests, quests, bosses";
  if (!m) return "";
  // Domain materials (talent books, weapon ascension): domain + rotation days are the key info.
  if (m.dropDomainName) {
    const days = daysLabel(m.daysOfWeek);
    return days ? `${m.dropDomainName} · ${days}` : m.dropDomainName;
  }
  const type = m.typeText ?? "";
  // A clean first source line adds value for boss/mob/specialty drops (skip placeholder text).
  const src = (m.sources ?? []).find(
    (s) => s && !/placeholder|stardust|souvenir|crafting|adventurer handbook|conversion/i.test(s),
  );
  if (type && src) return `${type} — ${src}`;
  return src || type || "";
}

const characters = JSON.parse(readFileSync(join(DATA, "characters.json"), "utf8")) as {
  ascensionMaterials?: { name: string }[];
  talentMaterials?: { name: string }[];
}[];
const weapons = JSON.parse(readFileSync(join(DATA, "weapons.json"), "utf8")) as {
  ascensionMaterials?: { name: string }[];
}[];

const names = new Set<string>();
for (const c of characters) {
  for (const mat of c.ascensionMaterials ?? []) names.add(mat.name);
  for (const mat of c.talentMaterials ?? []) names.add(mat.name);
}
for (const w of weapons) for (const mat of w.ascensionMaterials ?? []) names.add(mat.name);

const out: Record<string, string> = {};
for (const name of [...names].sort()) {
  const hint = hintFor(name);
  if (hint) out[name] = hint;
}

const body =
  "/** Auto-generated by packages/dataset/scripts/gen-material-sources.mts — do not edit by hand.\n" +
  " * A concise 'where to farm it' hint per material name, snapshotted from genshin-db (#6). */\n" +
  "export const MATERIAL_SOURCES: Record<string, string> = " +
  JSON.stringify(out, null, 2) +
  ";\n";
writeFileSync(OUT, body);
console.log(`Wrote ${Object.keys(out).length} material hints -> ${OUT}`);
